# Databricks cluster test configuration (copy to databricks_cluster_config.env and fill in).
# Used by: test_bundle_on_databricks.py (local + WorkspaceClient) and push_and_run_bundle_on_cluster.py (run on cluster).
#
# Authentication (choose one):
# - Set DATABRICKS_HOST and DATABRICKS_TOKEN (e.g. from Cursor/CI secrets), or
# - Use a profile: set DATABRICKS_CONFIG_PROFILE=myprofile (no host/token needed).
#
# For local test (bundle runs on your machine, uploads via SDK):
#   DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
#   DATABRICKS_TOKEN=dapi...
#   GBX_BUNDLE_VOLUME_CATALOG=main
#   GBX_BUNDLE_VOLUME_SCHEMA=default
#   GBX_BUNDLE_VOLUME_NAME=geobrix_samples
#
# For push-and-run (job runs on cluster):
#   CLUSTER_ID=your-cluster-id
#   GBX_ARTIFACT_VOLUME=your-volume-dir
#   - gbx:data:push-jar runs `mvn clean package -DskipTests` and uploads JAR to GBX_ARTIFACT_VOLUME/ (overwrite if exists);
#     set GBX_BUNDLE_SKIP_JAR_UPLOAD=1 to use existing JAR (no build/upload)
#   - gbx:data:push-wheel builds JAR first (push-jar) unless GBX_BUNDLE_SKIP_JAR_UPLOAD=1, then builds and uploads wheel to GBX_ARTIFACT_VOLUME/ (overwrite if exists);
#     set GBX_BUNDLE_SKIP_WHEEL_UPLOAD=1 to use existing wheel (no build/upload)

DATABRICKS_HOST=
DATABRICKS_TOKEN=
# Or use a profile (host and token from ~/.databrickscfg):
# DATABRICKS_CONFIG_PROFILE=default

# Volume root = /Volumes/<CATALOG>/<SCHEMA>/<VOLUME_NAME> (exactly 5 path segments).
# VOLUME_NAME must match Data Explorer exactly — hyphen vs underscore matters (e.g. sample-data not sample_data).
# On the cluster this path is FUSE-mounted; primitives use os.path / os.listdir / shutil.
GBX_BUNDLE_VOLUME_CATALOG=main
GBX_BUNDLE_VOLUME_SCHEMA=default
GBX_BUNDLE_VOLUME_NAME=geobrix_samples

# Required only for push_and_run_*_on_cluster.py
CLUSTER_ID=
GBX_ARTIFACT_VOLUME=

# Optional: skip build/upload when using gbx:data:push-jar or gbx:data:push-wheel
# GBX_BUNDLE_SKIP_JAR_UPLOAD=1
# GBX_BUNDLE_SKIP_WHEEL_UPLOAD=1

# Runner notebook location (preferred: dir + filename; else use GBX_BUNDLE_RUNNER_NOTEBOOK_PATH)
# GBX_RUNNER_DIR=/Workspace/Users/your-email@databricks.com/GeoBrix/gbx-beta-dbr-v0.2.0/sample-data/tests
# GBX_BUNDLE_RUNNER_NOTEBOOK=geobrix_bundle_runner.ipynb
# GBX_PRIMITIVE_RUNNER_NOTEBOOK=geobrix_primitive_runner.ipynb
# Or single path (legacy):
# GBX_BUNDLE_RUNNER_NOTEBOOK_PATH=/Workspace/geobrix_bundle_runner.ipynb
